        <mxCell value="⑤ Poll status&lt;br&gt;(every 10s)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.8;entryDx=0;entryDy=0;labelBackgroundColor=#F5F5F5;fontSize=11;strokeColor=#545B64;" edge="1" source="bb-pipeline" target="codebuild" parent="1">
