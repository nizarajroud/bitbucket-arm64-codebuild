        <mxCell value="logs" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;labelBackgroundColor=#F5F5F5;fontSize=11;strokeColor=#545B64;" edge="1" source="codebuild" target="cw" parent="aws-cloud">
          <mxGeometry relative="1" as="geometry" />
