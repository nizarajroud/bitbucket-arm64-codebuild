        </mxCell>
        <mxCell value="&lt;b&gt;Bitbucket → AWS CodeBuild ARM64 Pipeline&lt;/b&gt;&lt;br&gt;OIDC Authentication | No Static Keys" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=14;spacing=8;" vertex="1" parent="1">
